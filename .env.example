# ============================================
# Ephemeral Preview Environments — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. (.gitignore already excludes it)
#
# FREE-TIER SETUP GUIDE:
#   Render API key:  https://dashboard.render.com/settings#api-keys
#   GitHub token:    https://github.com/settings/tokens (scopes: repo)
#   MongoDB Atlas:   https://cloud.mongodb.com (512MB free forever)
# ============================================

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Trust proxy headers (set to true on Render/Heroku/Railway)
TRUST_PROXY=true

# ── Render API ────────────────────────────────────────────────
# Get from: https://dashboard.render.com/settings#api-keys
RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxxxxxx

# Get from: https://dashboard.render.com → Account Settings → Owner ID
RENDER_OWNER_ID=usr_xxxxxxxxxxxxxxxxxxxx

# ── GitHub ────────────────────────────────────────────────────
# Webhook secret: set when creating webhook in repo Settings > Webhooks
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Personal Access Token with: repo, write:discussion scopes
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────
PREVIEW_PREFIX=preview
BASE_REPO_URL=https://github.com/your-username/your-repo

# ── MongoDB (optional) ────────────────────────────────────────
# Leave empty → falls back to in-memory store (data lost on restart)
# Free tier: https://cloud.mongodb.com (512MB, no credit card)
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ephemeral-previews?retryWrites=true&w=majority

# ── Security ──────────────────────────────────────────────────
# CORS allowed origins — comma-separated list
# Leave empty to allow all in development
# Example: https://your-dashboard.vercel.app,https://admin.yourdomain.com
CORS_ORIGINS=

# Max request body size (default: 1mb)
BODY_LIMIT=1mb
